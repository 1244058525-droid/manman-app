{
  "schema_version": "1.0.0",
  "updated_at": "2026-05-06",
  "language": "zh-CN",
  "product_stage": "MVP_planning",
  "config_purpose": {
    "name": "companion_persona_system",
    "description": "A structured persona configuration for an AI companion product. It maps user questionnaire/profile signals to soft companion personas. Each persona provides display copy, response guidance, avoid rules, and profile tags.\n"
  },
  "core_principles": [
    {
      "id": "no_fixed_label",
      "text": "人格结果不是固定标签，不用于定义用户。"
    },
    {
      "id": "companion_first",
      "text": "情绪态下优先陪伴，不急着分析和解决。"
    },
    {
      "id": "no_diagnosis",
      "text": "不要做心理诊断，不使用病理化或评判性表达。"
    },
    {
      "id": "inference_not_fact",
      "text": "由问卷或对话推测出的画像信息只能标记为 inferred，不能直接当作 confirmed。"
    },
    {
      "id": "user_editable",
      "text": "画像和人格结果需要允许用户查看、修改、隐藏或删除。"
    },
    {
      "id": "low_pressure",
      "text": "所有结果页和陪伴文案都应保持低压、自然、有边界。"
    }
  ],
  "ui_global_copy": {
    "onboarding_result_intro": "我先轻轻认识你一点。根据你刚刚的回答，你现在更像「{persona_name}」。 这不是一个固定标签，也不是在定义你。它只是让我知道：当你累了、乱了、犹豫了，应该怎样靠近你，才不会打扰你。\n",
    "editable_notice": "这不是一个固定标签。如果之后你的状态变了，这份陪伴说明也会跟着更新。\n",
    "privacy_notice": "你可以随时修改、隐藏或删除这份陪伴说明。\n",
    "low_confidence_notice": "我现在只是根据你愿意告诉我的部分，先试着理解你一点。如果不准确，你可以随时改。\n",
    "secondary_persona_intro": "除了「{primary_persona_name}」，你身上也有一点「{secondary_persona_name}」的影子。\n"
  },
  "matching_config": {
    "description": "The persona matching engine should calculate scores from questionnaire answers, user profile fields, and later conversation signals. Do not rely on a single answer.\n",
    "output_format": {
      "primary_persona_id": "string",
      "secondary_persona_id": "string | null",
      "confidence": "low | medium | high",
      "evidence": "array",
      "source_type": "questionnaire | conversation | user_confirmation | system_inference",
      "status": "inferred | confirmed | rejected | outdated",
      "user_visible": true
    },
    "confidence_rules": {
      "low": {
        "description": "Only 1-2 weak signals are present. Use cautious copy.",
        "ui_behavior": "Show low_confidence_notice. Do not over-personalize."
      },
      "medium": {
        "description": "Multiple questionnaire signals point to the same persona.",
        "ui_behavior": "Show normal result copy with editable_notice."
      },
      "high": {
        "description": "Questionnaire signals and later conversation/user confirmation align.",
        "ui_behavior": "Can use persona to guide response behavior more strongly, but still avoid fixed-label language."
      }
    },
    "secondary_persona_rules": {
      "max_secondary_count": 1,
      "min_score_gap_for_secondary": 0.15,
      "description": "If the second highest persona score is close to the primary persona score, show one secondary persona. Do not show too many labels.\n"
    }
  },
  "readiness_state_map": {
    "emotional": {
      "response_priority": [
        "companion_mode",
        "gentle_validation",
        "low_questioning"
      ],
      "avoid": [
        "analysis_first",
        "advice_first",
        "action_plan_first"
      ]
    },
    "mixed": {
      "response_priority": [
        "reflection_mode",
        "gentle_mirroring",
        "optional_question"
      ],
      "avoid": [
        "hard_definition",
        "over_analysis"
      ]
    },
    "rational": {
      "response_priority": [
        "analysis_mode",
        "structured_explanation",
        "warm_summary"
      ],
      "avoid": [
        "cold_report_style",
        "excessive_options"
      ]
    },
    "action_ready": {
      "response_priority": [
        "action_mode",
        "one_small_next_step",
        "clear_recommendation"
      ],
      "avoid": [
        "too_many_solutions",
        "pressure_language"
      ]
    }
  },
